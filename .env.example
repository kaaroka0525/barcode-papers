# 실제 값을 채운 뒤 파일명을 .env 로 복사하세요. (.env 는 git에 올리지 마세요)

# ── 이메일 발송 ──
# Gmail 앱 비밀번호 16자리 (공백 포함/제외 무관)
GMAIL_APP_PASSWORD=xxxx xxxx xxxx xxxx

# ── 요약(AI) ──
# 로컬은 claude CLI로 대체 가능하지만, 서버 배포 시에는 필수.
ANTHROPIC_API_KEY=sk-ant-...

# ── 웹 서비스 / 배포 ──
# 세션 서명 키 (운영: 길고 무작위한 값으로)
WEB_SECRET_KEY=change-me-to-a-long-random-string
# DB. 로컬은 비워두면 SQLite. 배포는 Supabase Postgres URL.
DATABASE_URL=
# 서비스 공개 URL (배포 후 실제 도메인). OAuth 콜백/링크에 사용.
BASE_URL=http://127.0.0.1:8000
# 구글 로그인 (운영). 미설정 시 구글 버튼 숨김.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# 로컬 임시 로그인. 운영에서는 반드시 false.
ALLOW_DEV_LOGIN=true
